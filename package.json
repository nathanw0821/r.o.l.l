    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:seed:builder": "tsx src/scripts/seed-builder-only.ts",
    "db:sync-to-tsv": "tsx src/scripts/sync-database-to-tsv.ts"
  },
  "prisma": {
    "seed": "tsx src/seed.ts"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "hono": "4.12.19",
    "lodash": "4.17.23",
    "fast-uri": "3.1.2",
    "defu": "6.1.5",
    "ip-address": "10.1.1",
