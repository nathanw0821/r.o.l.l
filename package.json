    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.0",
    "postcss": "^8.5.10",
    "prisma": "^7.5.0",
    "tailwindcss": "^3.4.10",
