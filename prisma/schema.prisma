generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model DatasetVersion {
  id           String          @id @default(cuid())
  label        String
  sourceType   String
  sourceName   String?
  sourceUrl    String?
  syncMetadata Json?
  importedAt   DateTime        @default(now())
  isActive     Boolean         @default(true)
  effects      Effect[]
  effectTiers  EffectTier[]
  importAudits ImportAudit[]
  sheets       SourceDataset[]
}

model SourceDataset {
  id               String            @id @default(cuid())
  datasetVersionId String
  name             String
  sourcePath       String?
  canonical        Boolean           @default(false)
  headerColumns    Json?
  createdAt        DateTime          @default(now())
  datasetVersion   DatasetVersion    @relation(fields: [datasetVersionId], references: [id])
  rows             SourceEffectRow[]

  @@unique([datasetVersionId, name])
}

model SourceEffectRow {
  id               String        @id @default(cuid())
  datasetId        String
  rowIndex         Int
  rawColumns       Json
  tierLabel        String?
  effectName       String?
  categories       String?
  description      String?
  extraComponent   String?
  legendaryModules Int?
  unlockedRaw      String?
  notes            String?
  effectTierId     String?
  dataset          SourceDataset @relation(fields: [datasetId], references: [id])
  effectTier       EffectTier?   @relation(fields: [effectTierId], references: [id])

  @@unique([datasetId, rowIndex])
}

model Tier {
  id      Int          @id @default(autoincrement())
  label   String       @unique
  effects EffectTier[]
}

model Effect {
  id               String         @id @default(cuid())
  datasetVersionId String
  name             String
  datasetVersion   DatasetVersion @relation(fields: [datasetVersionId], references: [id])
  tiers            EffectTier[]

  @@unique([datasetVersionId, name])
}

model EffectTier {
  id               String               @id @default(cuid())
  datasetVersionId String
  effectId         String
  tierId           Int
  description      String?
  extraComponent   String?
  legendaryModules Int?
  notes            String?
  datasetVersion   DatasetVersion       @relation(fields: [datasetVersionId], references: [id])
  effect           Effect               @relation(fields: [effectId], references: [id])
  tier             Tier                 @relation(fields: [tierId], references: [id])
  categories       EffectTierCategory[]
  sourceRows       SourceEffectRow[]
  progress         UserProgress[]
  importBaselines  UserImportBaseline[]

  @@unique([datasetVersionId, effectId, tierId])
}

model Category {
  id      Int                  @id @default(autoincrement())
  name    String               @unique
  effects EffectTierCategory[]
}

model EffectTierCategory {
  effectTierId String
  categoryId   Int
  category     Category   @relation(fields: [categoryId], references: [id])
  effectTier   EffectTier @relation(fields: [effectTierId], references: [id])

  @@id([effectTierId, categoryId])
}

model User {
  id                      String               @id @default(cuid())
  username                String?              @unique
  passwordHash            String?
  authCode                String?
  secondaryCode           String?              @unique
  profileDatasetVersionId String?
  name                    String?
  email                   String?              @unique
  emailVerified           DateTime?
  image                   String?
  points                  Int                  @default(0)
  passivePointsAt         DateTime?
  lastAdWatchAt           DateTime?
  dailyPoints             Int                  @default(0)
  dailyPointsDate         DateTime?
  accounts                Account[]
  adRewardLogs            AdRewardLog[]
  achievements            UserAchievement[]
  importAudits            ImportAudit[]
  sessions                Session[]
  progress                UserProgress[]
  importBaseline          UserImportBaseline[]
  settings                UserSettings?
  storeUnlocks            UserStoreUnlock[]
  passwordResetTokens     PasswordResetToken[]
  feedbackSubmitted       Feedback[]            @relation("FeedbackSubmittedBy")
  feedbackReviewed        Feedback[]            @relation("FeedbackReviewedBy")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserSettings {
  id         String @id @default(cuid())
  userId     String @unique
  theme      String @default("system")
  accent     String @default("ember")
  density    String @default("comfortable")
  colorBlind String @default("none")
  adsEnabled Boolean @default(true)
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserProgress {
  id           String     @id @default(cuid())
  userId       String
  effectTierId String
  unlocked     Boolean    @default(false)
  notes        String?
  updatedAt    DateTime   @updatedAt
  effectTier   EffectTier @relation(fields: [effectTierId], references: [id])
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, effectTierId])
}

model UserImportBaseline {
  id               String     @id @default(cuid())
  userId           String
  datasetVersionId String
  effectTierId     String
  unlocked         Boolean
  createdAt        DateTime   @default(now())
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  effectTier       EffectTier @relation(fields: [effectTierId], references: [id])

  @@unique([userId, effectTierId])
  @@index([userId, datasetVersionId])
}

model UserAchievement {
  id         String   @id @default(cuid())
  userId     String
  key        String
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId, unlockedAt])
}

model AdRewardLog {
  id            String   @id @default(cuid())
  userId        String
  adSessionToken String  @unique
  provider      String
  status        String
  rewardAmount  Int
  grantedPoints Int?
  startedAt     DateTime @default(now())
  completedAt   DateTime?
  metadata      Json?
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, startedAt])
  @@index([userId, completedAt])
}

model UserStoreUnlock {
  id         String   @id @default(cuid())
  userId     String
  itemId     String
  cost       Int
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId, unlockedAt])
}

model ImportAudit {
  id               String          @id @default(cuid())
  userId           String?
  datasetVersionId String?
  filename         String
  status           String
  errorCount       Int             @default(0)
  errorSummary     Json?
  createdAt        DateTime        @default(now())
  completedAt      DateTime?
  datasetVersion   DatasetVersion? @relation(fields: [datasetVersionId], references: [id])
  user             User?           @relation(fields: [userId], references: [id])
}

model SyncSource {
  id              String   @id @default(cuid())
  name            String
  kind            String
  url             String?
  referenceUrl    String?
  format          String?
  enabled         Boolean  @default(true)
  lastSyncedAt    DateTime?
  lastStatus      String?
  lastError       String?
  lastCheckedAt   DateTime?
  lastChangedAt   DateTime?
  lastCheckStatus String?
  lastContentHash String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  runs            SyncRun[]

  @@unique([name])
}

model SyncRun {
  id               String   @id @default(cuid())
  status           String
  startedAt        DateTime @default(now())
  completedAt      DateTime?
  summary          Json?
  errorSummary     Json?
  datasetVersionId String?
  sourceId         String?
  source           SyncSource? @relation(fields: [sourceId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Feedback {
  id           String   @id @default(cuid())
  userId       String?
  subject      String
  message      String
  replyEmail   String?
  status       String   @default("new")
  adminNotes   String?
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  submittedBy  User?    @relation("FeedbackSubmittedBy", fields: [userId], references: [id], onDelete: SetNull)
  reviewedBy   User?    @relation("FeedbackReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
}
