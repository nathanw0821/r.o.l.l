generator client {
  provider      = "prisma-client-js"
  engineType    = "client"
  compilerBuild = "small"
}

datasource db {
  provider = "postgresql"
}

model DatasetVersion {
  id           String          @id @default(cuid())
  label        String
  sourceType   String
  importedAt   DateTime        @default(now())
  isActive     Boolean         @default(true)
  sourceName   String?
  sourceUrl    String?
  syncMetadata Json?
  effects      Effect[]
  effectTiers  EffectTier[]
  importAudits ImportAudit[]
  sheets       SourceDataset[]
}

model SourceDataset {
  id               String            @id @default(cuid())
  datasetVersionId String
  name             String
  sourcePath       String?
  canonical        Boolean           @default(false)
  headerColumns    Json?
  createdAt        DateTime          @default(now())
  datasetVersion   DatasetVersion    @relation(fields: [datasetVersionId], references: [id])
  rows             SourceEffectRow[]

  @@unique([datasetVersionId, name])
}

model SourceEffectRow {
  id               String        @id @default(cuid())
  datasetId        String
  rowIndex         Int
  rawColumns       Json
  tierLabel        String?
  effectName       String?
  categories       String?
  description      String?
  extraComponent   String?
  legendaryModules Int?
  unlockedRaw      String?
  notes            String?
  effectTierId     String?
  dataset          SourceDataset @relation(fields: [datasetId], references: [id])
  effectTier       EffectTier?   @relation(fields: [effectTierId], references: [id])

  @@unique([datasetId, rowIndex])
}

model Tier {
  id      Int          @id @default(autoincrement())
  label   String       @unique
  effects EffectTier[]
}

model Effect {
  id               String         @id @default(cuid())
  datasetVersionId String
  name             String
  datasetVersion   DatasetVersion @relation(fields: [datasetVersionId], references: [id])
  tiers            EffectTier[]

  @@unique([datasetVersionId, name])
}

model EffectTier {
  id               String               @id @default(cuid())
  datasetVersionId String
  effectId         String
  tierId           Int
  description      String?
  extraComponent   String?
  legendaryModules Int?
  notes            String?
  datasetVersion   DatasetVersion       @relation(fields: [datasetVersionId], references: [id])
  effect           Effect               @relation(fields: [effectId], references: [id])
  tier             Tier                 @relation(fields: [tierId], references: [id])
  categories       EffectTierCategory[]
  sourceRows       SourceEffectRow[]
  importBaselines  UserImportBaseline[]
  progress         UserProgress[]

  @@unique([datasetVersionId, effectId, tierId])
}

model Category {
  id      Int                  @id @default(autoincrement())
  name    String               @unique
  effects EffectTierCategory[]
}

model EffectTierCategory {
  effectTierId String
  categoryId   Int
  category     Category   @relation(fields: [categoryId], references: [id])
  effectTier   EffectTier @relation(fields: [effectTierId], references: [id])

  @@id([effectTierId, categoryId])
}

model User {
  id                      String                 @id @default(cuid())
  name                    String?
  email                   String?                @unique
  emailVerified           DateTime?
  image                   String?
  authCode                String?
  secondaryCode           String?                @unique
  profileDatasetVersionId String?
  passwordHash            String?
  username                String?                @unique
  points                  Int                    @default(0)
  lastAdWatchAt           DateTime?
  dailyPoints             Int                    @default(0)
  dailyPointsDate         DateTime?
  passivePointsAt         DateTime?
  accounts                Account[]
  gameAccounts            GameAccount[]
  adRewardLogs            AdRewardLog[]
  characters              Character[]
  feedbackReviewed        Feedback[]             @relation("FeedbackReviewedBy")
  feedbackSubmitted       Feedback[]             @relation("FeedbackSubmittedBy")
  importAudits            ImportAudit[]
  passwordResetTokens     PasswordResetToken[]
  sessions                Session[]
  sharedBuilds            SharedBuild[]
  achievements            UserAchievement[]
  importBaseline          UserImportBaseline[]
  learnedBasePieces       UserLearnedBasePiece[]
  progress                UserProgress[]
  settings                UserSettings?
  createdAt               DateTime               @default(now())
  storeUnlocks            UserStoreUnlock[]
  uuid                    String?                @unique @default(uuid())
  agreedToTerms           Boolean                @default(false)
}

/// Curated legendary mod catalog for the loadout builder (separate from import `Effect` rows).
model LegendaryMod {
  id                  String   @id @default(cuid())
  slug                String   @unique
  name                String
  /// 1–5 matching bench slots (5 = post–2026 fifth-star style entries in this seed).
  starRank            Int
  /// Weapon | Armor | Universal
  category            String
  /// Melee | Ranged | Energy when category is Weapon; null otherwise.
  subCategory         String?
  description         String   @default("")
  effectMath          Json     @default("{}")
  craftingCost        Json     @default("{}")
  allowedOnPowerArmor Boolean  @default(true)
  allowedOnArmor      Boolean  @default(true)
  allowedOnWeapon     Boolean  @default(true)
  /// Legacy flag; builder filters ignore infestation-only rows (column retained for old rows).
  infestationOnly     Boolean  @default(false)
  fifthStarEligible   Boolean  @default(false)
  /// When set, SPECIAL-style bonuses from effectMath are capped for Ghoul builds (e.g. Unyielding +2).
  ghoulSpecialCap     Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([starRank, category])
}

/// Saved sandbox builds for share links (`/l/[slug]`).
model SharedBuild {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  seoTitle    String?
  description String?
  payload     Json
  published   Boolean  @default(true)
  userId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User?    @relation(fields: [userId], references: [id])

  @@index([slug])
  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  refresh_token_expires_in Int?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserSettings {
  id                String     @id @default(cuid())
  userId            String     @unique
  theme             String     @default("system")
  accent            String     @default("ember")
  density           String     @default("comfortable")
  colorBlind        String     @default("none")
  adsEnabled        Boolean    @default(true)
  activeCharacterId String?
  activeCharacter   Character? @relation(fields: [activeCharacterId], references: [id])
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GameAccount {
  id         String      @id @default(cuid())
  userId     String
  name       String      // e.g. "Account 1", "Account 2"
  platform   String      @default("PC") // "PC", "XBOX", "PS"
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  characters Character[]

  @@unique([userId, name])
  @@index([userId])
}

model Character {
  id                 String                 @id @default(cuid())
  userId             String
  gameAccountId      String?
  name               String
  slotIndex          Int                    @default(0) // 0-4 for 5 characters per account
  legendaryModules   Int                    @default(0)
  scrip              Int                    @default(0)
  isMule             Boolean                @default(false)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  user               User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameAccount        GameAccount?           @relation(fields: [gameAccountId], references: [id], onDelete: SetNull)
  importBaseline     UserImportBaseline[]
  learnedBasePieces  UserLearnedBasePiece[]
  progress           UserProgress[]
  activeUserSettings UserSettings[]

  @@unique([userId, name])
  @@index([userId])
  @@index([gameAccountId])
}

model UserProgress {
  id           String     @id @default(cuid())
  userId       String
  effectTierId String
  unlocked     Boolean    @default(false)
  notes        String?
  updatedAt    DateTime   @updatedAt
  characterId  String
  isSeeking    Boolean    @default(false)
  modCount     Int        @default(0)
  character    Character  @relation(fields: [characterId], references: [id], onDelete: Cascade)
  effectTier   EffectTier @relation(fields: [effectTierId], references: [id])
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([characterId, effectTierId], name: "characterId_effectTierId")
  @@index([userId])
}

/// Builder catalog bases the user has learned in-game (armor sets, power armor, underarmor shells).
model UserLearnedBasePiece {
  userId      String
  basePieceId String
  createdAt   DateTime  @default(now())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([characterId, basePieceId])
  @@index([userId])
}

model UserImportBaseline {
  id               String     @id @default(cuid())
  userId           String
  datasetVersionId String
  effectTierId     String
  unlocked         Boolean
  createdAt        DateTime   @default(now())
  characterId      String
  character        Character  @relation(fields: [characterId], references: [id], onDelete: Cascade)
  effectTier       EffectTier @relation(fields: [effectTierId], references: [id])
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([characterId, effectTierId])
  @@index([userId, datasetVersionId])
}

model UserAchievement {
  id         String   @id @default(cuid())
  userId     String
  key        String
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId, unlockedAt])
}

model AdRewardLog {
  id             String    @id @default(cuid())
  userId         String
  adSessionToken String    @unique
  provider       String
  status         String
  rewardAmount   Int
  grantedPoints  Int?
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  metadata       Json?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, startedAt])
  @@index([userId, completedAt])
}

model UserStoreUnlock {
  id         String   @id @default(cuid())
  userId     String
  itemId     String
  cost       Int
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId, unlockedAt])
}

model ImportAudit {
  id               String          @id @default(cuid())
  userId           String?
  datasetVersionId String?
  filename         String
  status           String
  errorCount       Int             @default(0)
  errorSummary     Json?
  createdAt        DateTime        @default(now())
  completedAt      DateTime?
  datasetVersion   DatasetVersion? @relation(fields: [datasetVersionId], references: [id])
  user             User?           @relation(fields: [userId], references: [id])
}

model SyncSource {
  id              String    @id @default(cuid())
  name            String    @unique
  kind            String
  url             String?
  format          String?
  enabled         Boolean   @default(true)
  lastSyncedAt    DateTime?
  lastStatus      String?
  lastError       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastChangedAt   DateTime?
  lastCheckStatus String?
  lastCheckedAt   DateTime?
  lastContentHash String?
  referenceUrl    String?
  runs            SyncRun[]
}

model SyncRun {
  id               String      @id @default(cuid())
  status           String
  startedAt        DateTime    @default(now())
  completedAt      DateTime?
  summary          Json?
  errorSummary     Json?
  datasetVersionId String?
  sourceId         String?
  source           SyncSource? @relation(fields: [sourceId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Feedback {
  id           String    @id @default(cuid())
  userId       String?
  subject      String
  message      String
  replyEmail   String?
  status       String    @default("new")
  adminNotes   String?
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  reviewedBy   User?     @relation("FeedbackReviewedBy", fields: [reviewedById], references: [id])
  submittedBy  User?     @relation("FeedbackSubmittedBy", fields: [userId], references: [id])

  @@index([status, createdAt])
}

model VisitorStats {
  id           String   @id @default(cuid())
  date         DateTime @unique @default(now())
  guestHits    Int      @default(0)
  userHits     Int      @default(0)
  uniqueGuests Int      @default(0)
  uniqueUsers  Int      @default(0)

  @@index([date])
}
