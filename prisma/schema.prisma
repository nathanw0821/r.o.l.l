// Prisma schema for R.O.L.L.

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

// -----------------------------
// Dataset versions (raw source + normalized)
// -----------------------------
model DatasetVersion {
  id          String        @id @default(cuid())
  label       String
  sourceType  String
  importedAt  DateTime      @default(now())
  isActive    Boolean       @default(true)
  sheets      SourceDataset[]
  effects     Effect[]
  effectTiers EffectTier[]
}

// -----------------------------
// Source dataset (raw rows)
// -----------------------------
model SourceDataset {
  id               String           @id @default(cuid())
  datasetVersionId String
  name             String
  sourcePath       String?
  canonical        Boolean          @default(false)
  headerColumns    Json?
  createdAt        DateTime         @default(now())
  rows             SourceEffectRow[]

  datasetVersion   DatasetVersion   @relation(fields: [datasetVersionId], references: [id])

  @@unique([datasetVersionId, name])
}

model SourceEffectRow {
  id               String       @id @default(cuid())
  datasetId        String
  rowIndex         Int
  rawColumns       Json
  tierLabel        String?
  effectName       String?
  categories       String?
  description      String?
  extraComponent   String?
  legendaryModules Int?
  unlockedRaw      String?
  notes            String?

  // Optional link to normalized entry
  effectTierId     String?

  dataset          SourceDataset @relation(fields: [datasetId], references: [id])
  effectTier       EffectTier?   @relation(fields: [effectTierId], references: [id])

  @@unique([datasetId, rowIndex])
}

// -----------------------------
// Normalized app dataset
// -----------------------------
model Tier {
  id      Int          @id @default(autoincrement())
  label   String       @unique
  effects EffectTier[]
}

model Effect {
  id               String       @id @default(cuid())
  datasetVersionId String
  name             String
  tiers            EffectTier[]

  datasetVersion   DatasetVersion @relation(fields: [datasetVersionId], references: [id])

  @@unique([datasetVersionId, name])
}

model EffectTier {
  id               String               @id @default(cuid())
  datasetVersionId String
  effectId         String
  tierId           Int
  description      String?
  extraComponent   String?
  legendaryModules Int?
  notes            String?

  effect           Effect               @relation(fields: [effectId], references: [id])
  tier             Tier                 @relation(fields: [tierId], references: [id])
  datasetVersion   DatasetVersion       @relation(fields: [datasetVersionId], references: [id])
  sourceRows       SourceEffectRow[]
  categories       EffectTierCategory[]
  progress         UserProgress[]

  @@unique([datasetVersionId, effectId, tierId])
}

model Category {
  id      Int                  @id @default(autoincrement())
  name    String               @unique
  effects EffectTierCategory[]
}

model EffectTierCategory {
  effectTierId String
  categoryId   Int

  effectTier   EffectTier @relation(fields: [effectTierId], references: [id])
  category     Category   @relation(fields: [categoryId], references: [id])

  @@id([effectTierId, categoryId])
}

// -----------------------------
// User progress (separate from source)
// -----------------------------
model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  progress      UserProgress[]
  settings      UserSettings?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserSettings {
  id         String  @id @default(cuid())
  userId     String  @unique
  theme      String  @default("system")
  accent     String  @default("ember")
  density    String  @default("comfortable")
  colorBlind String  @default("none")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserProgress {
  id           String   @id @default(cuid())
  userId       String
  effectTierId String
  unlocked     Boolean  @default(false)
  notes        String?
  updatedAt    DateTime @updatedAt

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  effectTier   EffectTier @relation(fields: [effectTierId], references: [id])

  @@unique([userId, effectTierId])
}
